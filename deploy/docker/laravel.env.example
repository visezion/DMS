APP_NAME=DMS
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=dms
DB_USERNAME=dms
DB_PASSWORD=change_me
# For SQLite:
# DB_CONNECTION=sqlite
# DB_DATABASE=/var/www/html/storage/database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=dms_prod

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@dms.example.com"
MAIL_FROM_NAME="${APP_NAME}"

DMS_ENFORCE_MTLS=false
DMS_COMMAND_SIGNING_REQUIRED=true
DMS_KEYSET_CACHE_SECONDS=300
DMS_SIGNATURE_MODE=digest
DMS_SIGNATURE_COMPAT_MODES=digest,canonical,digest_hex,raw_json,raw_json_digest
DMS_SIGNATURE_DEBUG=false

# Agent backend (auto-managed in Docker mode)
AGENT_BACKEND_WORKDIR=/var/www/html/agent-backend
AGENT_BACKEND_HOST=agent-backend
AGENT_BACKEND_PORT=8000
# Optional manual launcher override for Admin -> Agent Delivery button:
# AGENT_BACKEND_START_COMMAND="python -m uvicorn app.main:app --host 127.0.0.1 --port 8000"
