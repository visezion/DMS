APP_NAME=DMS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=dms
DB_USERNAME=dms
DB_PASSWORD=dms

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=dms

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@dms.local"
MAIL_FROM_NAME="${APP_NAME}"

DMS_ENFORCE_MTLS=false
DMS_COMMAND_SIGNING_REQUIRED=true
DMS_KEYSET_CACHE_SECONDS=300
DMS_SIGNATURE_MODE=digest
DMS_SIGNATURE_COMPAT_MODES=digest,canonical,digest_hex,raw_json,raw_json_digest
# Agent-side emergency switch (set on endpoint environment, not backend):
# DMS_SIGNATURE_BYPASS=true
DMS_SIGNATURE_DEBUG=false

# Optional local Python backend launcher used by Admin -> Agent Delivery
# AGENT_BACKEND_WORKDIR=/opt/apps/agent-backend
# AGENT_BACKEND_WORKDIR=C:\path\to\python-backend
# AGENT_BACKEND_START_COMMAND=python -m uvicorn app.main:app --host 127.0.0.1 --port 8000
# AGENT_BACKEND_HOST=127.0.0.1
# AGENT_BACKEND_PORT=8000

